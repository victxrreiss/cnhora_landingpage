# Environment Variables Template
# Copie este arquivo para .env e preencha os ponteiros conforme seu .master_keys.env
# cp .env.example .env
#
# Os valores aqui são NOMES de chaves (não as chaves em si).
# A função dev() do PowerShell resolve os ponteiros em tempo de execução.

# --- CURSOR ---
USE_CURSOR_PROFILE=KEY_CURSOR_GROWERTECHNOLOGIESLTDA

# --- CLAUDE ---
USE_CLAUDE_ACCOUNT=KEY_CLAUDE_GROWERTECHNOLOGIESLTDA

# --- GEMINI ---
USE_GEMINI_ACCOUNT=KEY_GEMINI_VICTOR

# --- GITHUB ---
USE_GITHUB_ACCOUNT=KEY_GITHUB_VICTOR

# --- VERCEL ---
USE_VERCEL_TOKEN=KEY_VERCEL_VICTOR

# --- SUPABASE ---
USE_SUPABASE_KEY=KEY_SUPABASE_VICTOR
USE_SUPABASE_URL=

# --- SEO / Analytics ---
# Production host used by sitemap generator and (eventually) per-route canonicals.
# Currently cnhora.com.br; cutover to cnhora.com is a documented later step.
VITE_SITE_URL=https://cnhora.com.br
# Google Search Console verification token (paste the content="..." value from the
# meta tag verification method). Leave empty until the property is created.
VITE_GSC_VERIFICATION=
# Google Analytics 4 measurement ID, e.g. G-XXXXXXX. Leave empty to skip GA snippet.
VITE_GA4_MEASUREMENT_ID=
